{
  "name": "spec2cli",
  "version": "0.6.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spec2cli": "dist/index.js",
    "tocli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
