  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucianfialho/spec2cli.git"
  },
  "homepage": "https://github.com/lucianfialho/spec2cli",
  "bugs": {
    "url": "https://github.com/lucianfialho/spec2cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "swagger2openapi": "^7.0.8",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
